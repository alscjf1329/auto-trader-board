# SQLite DB 경로 (기본: ./data/trades.db)
DB_PATH=./data/trades.db

# ── auto-trader 제어 서버 연동 (선택) ─────────────────────────────
# auto-trader에서 python control.py 실행 후 아래 설정
# Docker에서 실행 중이면 host.docker.internal 사용 (docker-compose.yml 기본값)
# 로컬 개발 시: http://localhost:5001
CONTROL_ENDPOINT=http://localhost:5001
CONTROL_SECRET=
